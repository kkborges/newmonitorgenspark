# ============================================================
# Nexus Platform v4.0 — Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to git!
# ============================================================

# ── App ─────────────────────────────────────────────────────
SECRET_KEY=GENERATE_WITH__openssl_rand_hex_64
PLATFORM_URL=https://monitor.yourdomain.com
DEBUG=false

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nexus
POSTGRES_USER=nexus
POSTGRES_PASSWORD=CHANGE_TO_STRONG_PASSWORD

# ── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_TO_STRONG_PASSWORD

# ── AI Provider (pick one) ───────────────────────────────────
AI_PROVIDER=openai          # openai | anthropic | gemini

OPENAI_API_KEY=sk-...       # https://platform.openai.com/api-keys
OPENAI_MODEL=gpt-4o-mini    # gpt-4o | gpt-4o-mini | gpt-3.5-turbo

# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.0-flash

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=app_password_here
SMTP_FROM=nexus@yourdomain.com
SMTP_TLS=true

# ── Notification Channels ───────────────────────────────────
# SLACK_BOT_TOKEN=xoxb-...
# TELEGRAM_BOT_TOKEN=123456:ABC-...
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...
# DISCORD_WEBHOOK=https://discord.com/api/webhooks/...
# PAGERDUTY_KEY=...
# OPSGENIE_KEY=...
# WHATSAPP_TOKEN=...

# ── AWS ──────────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=us-east-1

# ── Azure ────────────────────────────────────────────────────
# AZURE_TENANT_ID=...
# AZURE_CLIENT_ID=...
# AZURE_CLIENT_SECRET=...
# AZURE_SUBSCRIPTION_ID=...

# ── Google Cloud ─────────────────────────────────────────────
# GCP_PROJECT_ID=my-project
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json

# ── VMware ───────────────────────────────────────────────────
# VMWARE_HOST=vcenter.yourdomain.com
# VMWARE_USER=administrator@vsphere.local
# VMWARE_PASSWORD=...

# ── Kubernetes ───────────────────────────────────────────────
# KUBECONFIG_PATH=/home/user/.kube/config
# K8S_IN_CLUSTER=false

# ── Flower (Celery UI) ───────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_TO_STRONG_PASSWORD

# ── Grafana (optional) ───────────────────────────────────────
# GRAFANA_PASSWORD=admin

# ── PgAdmin (dev only) ───────────────────────────────────────
# PGADMIN_PASSWORD=admin
